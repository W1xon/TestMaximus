<Window
    AllowsTransparency="True"
    Background="Transparent"
    Height="230"
    ResizeMode="NoResize"
    Title="ModernDialog"
    Width="520"
    WindowStyle="None"
    mc:Ignorable="d"
    x:Class="Maximus.Views.ModernDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Maximus.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border
        Background="{StaticResource BackgroundDark}"
        BorderBrush="{StaticResource BorderColor}"
        BorderThickness="1"
        CornerRadius="16">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="24"
                Color="Black"
                Opacity="0.4"
                ShadowDepth="0" />
        </Border.Effect>

        <Grid Margin="20,14,20,10" MinHeight="80">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!--  Header  -->
                <RowDefinition Height="Auto" />
                <!--  Message  -->
                <RowDefinition Height="Auto" />
                <!--  Buttons  -->
            </Grid.RowDefinitions>

            <!--  Header with Icon and Title  -->
            <StackPanel
                Grid.Row="0"
                Margin="0,0,0,10"
                Orientation="Horizontal">

                <!--  Type Indicator  -->
                <Ellipse
                    Fill="{StaticResource AccentSecondary}"
                    Height="12"
                    VerticalAlignment="Center"
                    Width="12"
                    x:Name="TypeAccent">
                    <Ellipse.Effect>
                        <DropShadowEffect
                            BlurRadius="8"
                            Color="#00FFFF"
                            Opacity="0.7"
                            ShadowDepth="0" />
                    </Ellipse.Effect>
                </Ellipse>

                <!--  Dialog Title  -->
                <TextBlock
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimary}"
                    Margin="12,0,0,0"
                    Style="{StaticResource H2Style}"
                    VerticalAlignment="Center"
                    x:Name="TxtTitle" />
            </StackPanel>

            <!--  Message Content  -->
            <TextBlock
                Foreground="{StaticResource TextSecondary}"
                Grid.Row="1"
                LineHeight="20"
                Margin="0,0,0,10"
                Style="{StaticResource BodyStyle}"
                TextWrapping="Wrap"
                x:Name="TxtMessage" />

            <!--  Action Buttons  -->
            <StackPanel
                Grid.Row="2"
                HorizontalAlignment="Right"
                Orientation="Horizontal">

                <Button
                    Click="Cancel_Click"
                    Content="Отмена"
                    Margin="0,0,8,0"
                    MinHeight="46"
                    Opacity="0.7"
                    Padding="14,8"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Visibility="Collapsed"
                    Width="100"
                    x:Name="BtnCancel" />

                <Button
                    Click="Ok_Click"
                    Content="Закрыть"
                    MinHeight="46"
                    Padding="14,8"
                    Style="{StaticResource ButtonStyle}"
                    Width="100"
                    x:Name="BtnOk" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
