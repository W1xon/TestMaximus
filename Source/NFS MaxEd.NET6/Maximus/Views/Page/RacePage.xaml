<Page
    Background="Transparent"
    Title="RacePage"
    mc:Ignorable="d"
    x:Class="Maximus.Views.RacePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Maximus.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20,20,20,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                DataContext="{Binding Config}"
                Grid.Row="0"
                Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="90" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,30,0">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="Race Type" />
                        <ComboBox
                            HorizontalAlignment="Left"
                            ItemsSource="{Binding NodeTypes}"
                            SelectedItem="{Binding NodeType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            SelectionChanged="ComboBox_SelectionChanged"
                            x:Name="NodeType" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock
                            Margin="0,0,0,10"
                            Style="{StaticResource LabelStyle}"
                            Text="Race Options" />
                        <WrapPanel>
                            <CheckBox Content="Boss Races" IsChecked="{Binding BossRaces, Mode=TwoWay}" />
                            <CheckBox Content="Available QR" IsChecked="{Binding AvailableQR, Mode=TwoWay}" />
                            <CheckBox Content="Cops in Race" IsChecked="{Binding EnableCops, Mode=TwoWay}" />
                            <CheckBox Content="Chance of Rain" IsChecked="{Binding IsChanceOfRain, Mode=TwoWay}" />
                            <Button
                                Click="ShowCashgrabInfo_OnClick"
                                Content="?"
                                Style="{StaticResource InfoButtonStyle}"
                                Visibility="{Binding IsCashgrab, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <Button
                                Click="ShowDragInfo_OnClick"
                                Content="?"
                                Style="{StaticResource InfoButtonStyle}"
                                Visibility="{Binding IsDrag, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </WrapPanel>
                    </StackPanel>
                    <Button
                        Background="{StaticResource BackgroundDark}"
                        BorderBrush="{StaticResource BorderColor}"
                        Click="OpenMap_Click"
                        FontSize="32"
                        Foreground="{StaticResource TextPrimary}"
                        Grid.Column="2"
                        HorizontalAlignment="Center"
                        Style="{StaticResource ButtonStyle}"
                        VerticalAlignment="Center"
                        Width="80">
                        <Image
                            Height="48"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,5"
                            Source="pack://application:,,,/Assets/Map_Icon.png"
                            Stretch="Uniform"
                            VerticalAlignment="Center"
                            Width="48" />
                    </Button>
                </Grid>
            </Border>

            <Border
                DataContext="{Binding Config}"
                Grid.Row="1"
                Style="{StaticResource CardStyle}">
                <ScrollViewer
                    HorizontalAlignment="Stretch"
                    HorizontalScrollBarVisibility="Visible"
                    PreviewMouseWheel="ScrollViewer_PreviewMouseWheel"
                    VerticalAlignment="Stretch"
                    VerticalScrollBarVisibility="Disabled"
                    x:Name="SettingsScrollViewer">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top">

                        <!--  1. IDENTIFICATION  -->
                        <Border
                            Margin="0,0,15,0"
                            Style="{StaticResource AuthorCardStyle}"
                            Width="380">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Event ID" />
                                <TextBox Margin="0,0,0,10" Text="{Binding EventId}" />
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Gameplay Vault" />
                                <TextBox Margin="0,0,0,10" Text="{Binding GameplayVault}" />
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Race Bin" />
                                <ComboBox
                                    ItemsSource="{Binding RaceBins}"
                                    Margin="0,0,0,10"
                                    SelectedItem="{Binding RaceBin}" />
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Region" />
                                <ComboBox ItemsSource="{Binding Regions}" SelectedItem="{Binding Region}" />
                            </StackPanel>
                        </Border>

                        <!--  2. PRESENTATION  -->
                        <Border
                            Margin="0,0,15,0"
                            Style="{StaticResource AuthorCardStyle}"
                            Width="380">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Intro NIS" />

                                <ComboBox
                                    ItemsSource="{Binding IntroNisList}"
                                    Margin="0,0,0,10"
                                    SelectedItem="{Binding IntroNis}" />
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Finish Camera" />

                                <ComboBox ItemsSource="{Binding FinishCameraList}" SelectedItem="{Binding FinishCamera, Mode=TwoWay}" />
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Cash Value" />
                                <TextBox Margin="0,0,0,10" Text="{Binding CashValue}" />
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Race Length" />
                                <TextBox Text="{Binding RaceLength}" />
                            </StackPanel>
                        </Border>

                        <!--  3. GAMEPLAY SETTINGS  -->
                        <Border
                            Margin="0,0,15,0"
                            Style="{StaticResource AuthorCardStyle}"
                            Width="380">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Force Heat" />
                                        <TextBox IsEnabled="{Binding EnableCops}" Text="{Binding ForceHeatLevel}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Max Heat" />
                                        <TextBox IsEnabled="{Binding EnableCops}" Text="{Binding MaxHeatLevel}" />
                                    </StackPanel>
                                </Grid>

                                <TextBlock Style="{StaticResource LabelStyle}" Text="Traffic Level" />
                                <TextBox Margin="0,0,0,10" Text="{Binding TrafficLevel}" />
                                <TextBlock Style="{StaticResource LabelStyle}" Text="Chance of Rain" />
                                <TextBox
                                    IsEnabled="{Binding IsChanceOfRain}"
                                    Margin="0,0,0,10"
                                    Text="{Binding ChanceOfRain}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Laps" />
                                        <TextBox Text="{Binding NumLaps}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource LabelStyle}" Text="Reputation" />
                                        <TextBox Text="{Binding Reputation}" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!--  4. BARRIERS  -->
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock
                                Margin="0,0,0,8"
                                Style="{StaticResource LabelStyle}"
                                Text="Barriers" />
                            <Border
                                Height="380"
                                Style="{StaticResource AuthorCardStyle}"
                                Width="380">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Hidden">
                                        <ItemsControl ItemsSource="{Binding Barriers}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,5">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="30" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox
                                                            Grid.Column="0"
                                                            Margin="0,0,5,0"
                                                            MaxLength="5"
                                                            Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        <Button
                                                            Command="{Binding DataContext.RemoveBarrierCommand, RelativeSource={RelativeSource AncestorType=Border}}"
                                                            CommandParameter="{Binding .}"
                                                            Content="×"
                                                            Grid.Column="1"
                                                            Style="{StaticResource DeleteButtonStyle}" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <Button
                                        Command="{Binding AddBarrierCommand}"
                                        Content="+"
                                        Grid.Row="1"
                                        Margin="0,8,0,0"
                                        Style="{StaticResource ButtonStyle}" />
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!--  5. CHECKPOINTS  -->
                        <StackPanel Margin="0,0,15,0" Visibility="{Binding IsFinishAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock
                                Margin="0,0,0,8"
                                Style="{StaticResource LabelStyle}"
                                Text="Checkpoints" />
                            <Border
                                Height="380"
                                Style="{StaticResource AuthorCardStyle}"
                                Width="380">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Hidden">
                                        <ItemsControl ItemsSource="{Binding Checkpoints}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border
                                                        Background="{StaticResource BackgroundDark}"
                                                        BorderBrush="{StaticResource BorderColor}"
                                                        BorderThickness="1"
                                                        CornerRadius="3"
                                                        Margin="0,0,0,6"
                                                        Padding="6">
                                                        <StackPanel>
                                                            <Grid Margin="0,0,0,6">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="30" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBox
                                                                    FontSize="10"
                                                                    Grid.Column="0"
                                                                    Text="{Binding Name}"
                                                                    VerticalAlignment="Center" />
                                                                <Button
                                                                    Command="{Binding DataContext.RemoveCheckpointCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Content="×"
                                                                    Grid.Column="1"
                                                                    HorizontalAlignment="Right"
                                                                    Style="{StaticResource DeleteButtonStyle}" />
                                                            </Grid>
                                                            <UniformGrid Columns="3">
                                                                <StackPanel Margin="2,0">
                                                                    <TextBlock Style="{StaticResource MiniLabelStyle}" Text="X" />
                                                                    <TextBox Text="{Binding Point.PositionX}" />
                                                                </StackPanel>
                                                                <StackPanel Margin="2,0">
                                                                    <TextBlock Style="{StaticResource MiniLabelStyle}" Text="Y" />
                                                                    <TextBox Text="{Binding Point.PositionY}" />
                                                                </StackPanel>
                                                                <StackPanel Margin="2,0">
                                                                    <TextBlock Style="{StaticResource MiniLabelStyle}" Text="Z" />
                                                                    <TextBox Text="{Binding Point.PositionZ}" />
                                                                </StackPanel>
                                                            </UniformGrid>
                                                            <StackPanel Margin="2,4,2,0">
                                                                <TextBlock Style="{StaticResource MiniLabelStyle}" Text="Rotation (HEX)" />
                                                                <TextBox Text="{Binding Point.RotationHEX}" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <UniformGrid
                                        Grid.Row="1"
                                        Margin="0,10,0,0"
                                        Rows="1">
                                        <Button
                                            Command="{Binding AddCheckpointCommand}"
                                            Content="+"
                                            Style="{StaticResource ButtonStyle}" />
                                        <Button
                                            Command="{Binding AddTimeBonusCheckpointCommand}"
                                            Content="+ Time"
                                            Margin="5,0,0,0"
                                            Style="{StaticResource ButtonStyle}"
                                            Visibility="{Binding IsTollbooth, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </UniformGrid>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!--  6. SHORTCUTS  -->
                        <StackPanel Margin="0,0,15,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsShortcutAvailable}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock
                                Margin="0,0,0,8"
                                Style="{StaticResource LabelStyle}"
                                Text="Shortcuts" />
                            <Border
                                Height="380"
                                Style="{StaticResource AuthorCardStyle}"
                                Width="380">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Hidden">
                                        <ItemsControl ItemsSource="{Binding Shortcuts}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border
                                                        Background="{StaticResource BackgroundDark}"
                                                        BorderBrush="{StaticResource BorderColor}"
                                                        BorderThickness="1"
                                                        CornerRadius="3"
                                                        Margin="0,0,0,6"
                                                        Padding="6">
                                                        <StackPanel>
                                                            <Grid Margin="0,0,0,6">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="35" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBox FontSize="11" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                <Button
                                                                    Command="{Binding DataContext.RemoveShortcutCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Content="×"
                                                                    Grid.Column="1"
                                                                    Margin="4,0,0,0"
                                                                    Style="{StaticResource DeleteButtonStyle}" />
                                                            </Grid>
                                                            <UniformGrid Columns="4">
                                                                <StackPanel Margin="1,0">
                                                                    <TextBlock Style="{StaticResource MiniLabelStyle}" Text="X" />
                                                                    <TextBox FontSize="10" Text="{Binding Point.PositionX, Mode=TwoWay}" />
                                                                </StackPanel>
                                                                <StackPanel Margin="1,0">
                                                                    <TextBlock Style="{StaticResource MiniLabelStyle}" Text="Y" />
                                                                    <TextBox FontSize="10" Text="{Binding Point.PositionY, Mode=TwoWay}" />
                                                                </StackPanel>
                                                                <StackPanel Margin="1,0">
                                                                    <TextBlock Style="{StaticResource MiniLabelStyle}" Text="Z" />
                                                                    <TextBox FontSize="10" Text="{Binding Point.PositionZ, Mode=TwoWay}" />
                                                                </StackPanel>
                                                                <StackPanel Margin="1,0">
                                                                    <TextBlock Style="{StaticResource MiniLabelStyle}" Text="R" />
                                                                    <TextBox FontSize="10" Text="{Binding Point.RotationHEX, Mode=TwoWay}" />
                                                                </StackPanel>
                                                            </UniformGrid>
                                                            <UniformGrid Columns="2" Margin="0,6,0,0">
                                                                <StackPanel Margin="1,0">
                                                                    <TextBlock
                                                                        HorizontalAlignment="Left"
                                                                        Margin="4,0,0,0"
                                                                        Style="{StaticResource MiniLabelStyle}"
                                                                        Text="Min Chance" />
                                                                    <TextBox FontSize="10" Text="{Binding MinChance, Mode=TwoWay}" />
                                                                </StackPanel>
                                                                <StackPanel Margin="1,0">
                                                                    <TextBlock
                                                                        HorizontalAlignment="Left"
                                                                        Margin="4,0,0,0"
                                                                        Style="{StaticResource MiniLabelStyle}"
                                                                        Text="Max Chance" />
                                                                    <TextBox FontSize="10" Text="{Binding MaxChance, Mode=TwoWay}" />
                                                                </StackPanel>
                                                            </UniformGrid>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <Button
                                        Command="{Binding AddShortcutCommand}"
                                        Content="+"
                                        Grid.Row="1"
                                        Margin="0,8,0,0"
                                        Style="{StaticResource ButtonStyle}" />
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!--  7. SPEEDTRAPS  -->
                        <StackPanel Margin="0,0,15,0" Visibility="{Binding IsSpeedtrap, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock
                                Margin="0,0,0,8"
                                Style="{StaticResource LabelStyle}"
                                Text="Speedtraps" />
                            <Border
                                Height="380"
                                Style="{StaticResource AuthorCardStyle}"
                                Width="380">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Hidden">
                                        <ItemsControl ItemsSource="{Binding Speedtraps}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border
                                                        Background="{StaticResource BackgroundDark}"
                                                        BorderBrush="{StaticResource BorderColor}"
                                                        BorderThickness="1"
                                                        CornerRadius="3"
                                                        Margin="0,0,0,6"
                                                        Padding="6">
                                                        <StackPanel>
                                                            <Grid Margin="0,0,0,6">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="35" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBox FontSize="11" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                <Button
                                                                    Command="{Binding DataContext.RemoveSpeedtrapCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Content="×"
                                                                    Grid.Column="1"
                                                                    Margin="4,0,0,0"
                                                                    Style="{StaticResource DeleteButtonStyle}" />
                                                            </Grid>
                                                            <UniformGrid Columns="3">
                                                                <StackPanel Margin="2,0">
                                                                    <TextBlock Style="{StaticResource MiniLabelStyle}" Text="X" />
                                                                    <TextBox FontSize="10" Text="{Binding Point.PositionX, Mode=TwoWay}" />
                                                                </StackPanel>
                                                                <StackPanel Margin="2,0">
                                                                    <TextBlock Style="{StaticResource MiniLabelStyle}" Text="Y" />
                                                                    <TextBox FontSize="10" Text="{Binding Point.PositionY, Mode=TwoWay}" />
                                                                </StackPanel>
                                                                <StackPanel Margin="2,0">
                                                                    <TextBlock Style="{StaticResource MiniLabelStyle}" Text="Z" />
                                                                    <TextBox FontSize="10" Text="{Binding Point.PositionZ, Mode=TwoWay}" />
                                                                </StackPanel>
                                                            </UniformGrid>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <Button
                                        Command="{Binding AddSpeedtrapCommand}"
                                        Content="+"
                                        Grid.Row="1"
                                        Margin="0,8,0,0"
                                        Style="{StaticResource ButtonStyle}" />
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!--  8. CHARACTERS (IsDrag)  -->
                        <StackPanel Margin="0,0,15,0" Visibility="{Binding IsDrag, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock
                                Margin="0,0,0,8"
                                Style="{StaticResource LabelStyle}"
                                Text="Characters" />
                            <Border
                                Height="380"
                                Style="{StaticResource AuthorCardStyle}"
                                Width="380">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Hidden">
                                        <ItemsControl ItemsSource="{Binding CharacterDrugs}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border
                                                        Background="{StaticResource BackgroundDark}"
                                                        BorderBrush="{StaticResource BorderColor}"
                                                        BorderThickness="1"
                                                        CornerRadius="3"
                                                        Margin="0,0,0,6"
                                                        Padding="6">
                                                        <StackPanel>
                                                            <Grid Margin="0,0,0,8">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="26" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBox FontSize="11" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                <Button
                                                                    Command="{Binding DataContext.RemoveCharacterDrugCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Content="×"
                                                                    Grid.Column="1"
                                                                    Margin="4,0,0,0"
                                                                    Style="{StaticResource DeleteButtonStyle}" />
                                                            </Grid>
                                                            <TextBlock
                                                                Margin="4,0,0,2"
                                                                Style="{StaticResource MiniLabelStyle}"
                                                                Text="Car Type:" />
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="32" />
                                                                </Grid.ColumnDefinitions>
                                                                <ComboBox
                                                                    Background="{StaticResource BackgroundDark}"
                                                                    BorderBrush="{StaticResource BorderColor}"
                                                                    FontSize="11"
                                                                    Foreground="{StaticResource TextPrimary}"
                                                                    ItemsSource="{Binding CarTypes}"
                                                                    SelectedItem="{Binding SelectedCarType, Mode=TwoWay}" />
                                                                <Button
                                                                    Content="?"
                                                                    Grid.Column="1"
                                                                    Margin="4,0,0,0"
                                                                    Style="{StaticResource InfoButtonStyle}" />
                                                            </Grid>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <Button
                                        Command="{Binding AddCharacterDrugCommand}"
                                        Content="+"
                                        Grid.Row="1"
                                        Margin="0,8,0,0"
                                        Style="{StaticResource ButtonStyle}" />
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!--  9. TRAFFIC SPAWN TRIGGERS (IsDrag)  -->
                        <StackPanel Margin="0,0,15,0" Visibility="{Binding IsDrag, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock
                                Margin="0,0,0,8"
                                Style="{StaticResource LabelStyle}"
                                Text="Traffic Spawn Triggers" />
                            <Border
                                Height="380"
                                Style="{StaticResource AuthorCardStyle}"
                                Width="380">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding TrafficSpawnTriggers}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border
                                                        Background="{StaticResource BackgroundDark}"
                                                        BorderBrush="{StaticResource BorderColor}"
                                                        BorderThickness="1"
                                                        CornerRadius="3"
                                                        Margin="0,0,0,6"
                                                        Padding="6">
                                                        <StackPanel>
                                                            <Grid Margin="0,0,0,8">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="26" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBox FontSize="10" Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                                <Button
                                                                    Command="{Binding DataContext.RemoveCharacterDrugCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Content="×"
                                                                    Grid.Column="1"
                                                                    Margin="4,0,0,0"
                                                                    Style="{StaticResource DeleteButtonStyle}" />
                                                            </Grid>
                                                            <UniformGrid Columns="3">
                                                                <StackPanel Margin="1,0">
                                                                    <TextBlock Style="{StaticResource MiniLabelStyle}" Text="X" />
                                                                    <TextBox FontSize="10" Text="{Binding Point.PositionX, Mode=TwoWay}" />
                                                                </StackPanel>
                                                                <StackPanel Margin="1,0">
                                                                    <TextBlock Style="{StaticResource MiniLabelStyle}" Text="Y" />
                                                                    <TextBox FontSize="10" Text="{Binding Point.PositionY, Mode=TwoWay}" />
                                                                </StackPanel>
                                                                <StackPanel Margin="1,0">
                                                                    <TextBlock Style="{StaticResource MiniLabelStyle}" Text="Z" />
                                                                    <TextBox FontSize="10" Text="{Binding Point.PositionZ, Mode=TwoWay}" />
                                                                </StackPanel>
                                                            </UniformGrid>
                                                            <UniformGrid Columns="2" Margin="0,6,0,0">
                                                                <StackPanel Margin="1,0">
                                                                    <TextBlock Style="{StaticResource MiniLabelStyle}" Text="Rotation" />
                                                                    <TextBox FontSize="10" Text="{Binding Point.RotationHEX, Mode=TwoWay}" />
                                                                </StackPanel>
                                                                <StackPanel Margin="1,0">
                                                                    <TextBlock Style="{StaticResource MiniLabelStyle}" Text="Radius" />
                                                                    <TextBox FontSize="10" Text="{Binding Radius, Mode=TwoWay}" />
                                                                </StackPanel>
                                                            </UniformGrid>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <Button
                                        Command="{Binding AddTrafficSpawnTriggerCommand}"
                                        Content="+"
                                        Grid.Row="1"
                                        Margin="0,8,0,0"
                                        Style="{StaticResource ButtonStyle}" />
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!--  10. OPPONENT SPAWN (IsCashgrab)  -->
                        <StackPanel Margin="0,0,15,0" Visibility="{Binding IsCashgrab, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock
                                Margin="0,0,0,8"
                                Style="{StaticResource LabelStyle}"
                                Text="OpponentSpawn" />
                            <Border
                                Height="380"
                                Style="{StaticResource AuthorCardStyle}"
                                Width="380">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Hidden">
                                        <ItemsControl ItemsSource="{Binding CashgrabOpponentSpawns}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border
                                                        Background="{StaticResource BackgroundDark}"
                                                        BorderBrush="{StaticResource BorderColor}"
                                                        BorderThickness="1"
                                                        CornerRadius="3"
                                                        Margin="0,0,0,6"
                                                        Padding="6">
                                                        <StackPanel>
                                                            <Grid Margin="0,0,0,6">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="35" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBox
                                                                    FontSize="10"
                                                                    Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                    VerticalAlignment="Center" />
                                                                <Button
                                                                    Command="{Binding DataContext.RemoveOpponentSpawnCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Content="×"
                                                                    Grid.Column="1"
                                                                    HorizontalAlignment="Right"
                                                                    Style="{StaticResource DeleteButtonStyle}" />
                                                            </Grid>
                                                            <UniformGrid Columns="3">
                                                                <StackPanel Margin="1,0">
                                                                    <TextBlock Style="{StaticResource MiniLabelStyle}" Text="X" />
                                                                    <TextBox FontSize="10" Text="{Binding PositionX, Mode=TwoWay}" />
                                                                </StackPanel>
                                                                <StackPanel Margin="1,0">
                                                                    <TextBlock Style="{StaticResource MiniLabelStyle}" Text="Y" />
                                                                    <TextBox FontSize="10" Text="{Binding PositionY, Mode=TwoWay}" />
                                                                </StackPanel>
                                                                <StackPanel Margin="1,0">
                                                                    <TextBlock Style="{StaticResource MiniLabelStyle}" Text="Z" />
                                                                    <TextBox FontSize="10" Text="{Binding PositionZ, Mode=TwoWay}" />
                                                                </StackPanel>
                                                            </UniformGrid>
                                                            <StackPanel Margin="1,4,1,0">
                                                                <TextBlock Style="{StaticResource MiniLabelStyle}" Text="R (Rotation)" />
                                                                <TextBox FontSize="10" Text="{Binding RotationHEX, Mode=TwoWay}" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <TextBlock
                                        FontSize="10"
                                        Foreground="{StaticResource TextSecondary}"
                                        Grid.Row="1"
                                        HorizontalAlignment="Center"
                                        Margin="0,8,0,0"
                                        Text="Enter Opponents for Generate" />
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!--  11. MONEYBAG (IsCashgrab)  -->
                        <StackPanel Margin="0,0,15,0" Visibility="{Binding IsCashgrab, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock
                                Margin="0,0,0,8"
                                Style="{StaticResource LabelStyle}"
                                Text="Moneybag" />
                            <Border
                                Height="380"
                                Style="{StaticResource AuthorCardStyle}"
                                Width="380">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Hidden">
                                        <ItemsControl ItemsSource="{Binding Moneybags}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border
                                                        Background="{StaticResource BackgroundDark}"
                                                        BorderBrush="{StaticResource BorderColor}"
                                                        BorderThickness="1"
                                                        CornerRadius="3"
                                                        Margin="0,0,0,6"
                                                        Padding="6">
                                                        <StackPanel>
                                                            <Grid Margin="0,0,0,6">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="35" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBox
                                                                    FontSize="10"
                                                                    Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                    VerticalAlignment="Center" />
                                                                <Button
                                                                    Command="{Binding DataContext.RemoveMoneybag, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Content="×"
                                                                    Grid.Column="1"
                                                                    HorizontalAlignment="Right"
                                                                    Style="{StaticResource DeleteButtonStyle}" />
                                                            </Grid>
                                                            <UniformGrid Columns="3">
                                                                <StackPanel Margin="1,0">
                                                                    <TextBlock Style="{StaticResource MiniLabelStyle}" Text="X" />
                                                                    <TextBox FontSize="10" Text="{Binding Point.PositionX, Mode=TwoWay}" />
                                                                </StackPanel>
                                                                <StackPanel Margin="1,0">
                                                                    <TextBlock Style="{StaticResource MiniLabelStyle}" Text="Y" />
                                                                    <TextBox FontSize="10" Text="{Binding Point.PositionY, Mode=TwoWay}" />
                                                                </StackPanel>
                                                                <StackPanel Margin="1,0">
                                                                    <TextBlock Style="{StaticResource MiniLabelStyle}" Text="Z" />
                                                                    <TextBox FontSize="10" Text="{Binding Point.PositionZ, Mode=TwoWay}" />
                                                                </StackPanel>
                                                            </UniformGrid>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                    <UniformGrid
                                        Grid.Row="1"
                                        Margin="0,8,0,0"
                                        Rows="1">
                                        <Button
                                            Command="{Binding AddMoneybagSmallCommand}"
                                            Content="Small"
                                            Margin="2,0"
                                            Style="{StaticResource ButtonStyle}" />
                                        <Button
                                            Command="{Binding AddMoneybagMiddleCommand}"
                                            Content="Middle"
                                            Margin="2,0"
                                            Style="{StaticResource ButtonStyle}" />
                                        <Button
                                            Command="{Binding AddMoneybagBigCommand}"
                                            Content="Big"
                                            Margin="2,0"
                                            Style="{StaticResource ButtonStyle}" />
                                    </UniformGrid>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!--  12. START GRID  -->
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock
                                Margin="0,0,0,8"
                                Style="{StaticResource LabelStyle}"
                                Text="Start Grid" />
                            <Border
                                Height="380"
                                Style="{StaticResource AuthorCardStyle}"
                                Width="380">
                                <StackPanel Margin="8">
                                    <TextBox
                                        FontSize="10"
                                        IsEnabled="False"
                                        Margin="0,0,0,8"
                                        Text="{Binding StartGrid.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <UniformGrid Columns="3" Margin="0,0,0,6">
                                        <StackPanel Margin="1,0">
                                            <TextBlock Style="{StaticResource MiniLabelStyle}" Text="X" />
                                            <TextBox FontSize="10" Text="{Binding StartGrid.PositionX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="1,0">
                                            <TextBlock Style="{StaticResource MiniLabelStyle}" Text="Y" />
                                            <TextBox FontSize="10" Text="{Binding StartGrid.PositionY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="1,0">
                                            <TextBlock Style="{StaticResource MiniLabelStyle}" Text="Z" />
                                            <TextBox FontSize="10" Text="{Binding StartGrid.PositionZ, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </UniformGrid>
                                    <StackPanel Margin="1,0">
                                        <TextBlock Style="{StaticResource MiniLabelStyle}" Text="Rotation (HEX)" />
                                        <TextBox FontSize="10" Text="{Binding StartGrid.RotationHEX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!--  13. FINISH LINE  -->
                        <StackPanel Margin="0,0,15,0" Visibility="{Binding IsFinishAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock
                                Margin="0,0,0,8"
                                Style="{StaticResource LabelStyle}"
                                Text="Finish Line" />
                            <Border
                                Height="380"
                                Style="{StaticResource AuthorCardStyle}"
                                Width="380">
                                <StackPanel Margin="8">
                                    <TextBox
                                        FontSize="10"
                                        IsEnabled="False"
                                        Margin="0,0,0,8"
                                        Text="{Binding FinishLine.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock
                                        Foreground="{StaticResource TextSecondary}"
                                        Margin="4,0,0,2"
                                        Style="{StaticResource MiniLabelStyle}"
                                        Text="Position" />
                                    <UniformGrid Columns="3" Margin="0,0,0,8">
                                        <StackPanel Margin="1,0">
                                            <TextBlock Style="{StaticResource MiniLabelStyle}" Text="X" />
                                            <TextBox FontSize="10" Text="{Binding FinishLine.PositionX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="1,0">
                                            <TextBlock Style="{StaticResource MiniLabelStyle}" Text="Y" />
                                            <TextBox FontSize="10" Text="{Binding FinishLine.PositionY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="1,0">
                                            <TextBlock Style="{StaticResource MiniLabelStyle}" Text="Z" />
                                            <TextBox FontSize="10" Text="{Binding FinishLine.PositionZ, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </UniformGrid>
                                    <TextBlock
                                        Foreground="{StaticResource TextSecondary}"
                                        Margin="4,0,0,2"
                                        Style="{StaticResource MiniLabelStyle}"
                                        Text="Dimensions" />
                                    <UniformGrid Columns="3" Margin="0,0,0,8">
                                        <StackPanel Margin="1,0">
                                            <TextBlock Style="{StaticResource MiniLabelStyle}" Text="X" />
                                            <TextBox FontSize="10" Text="{Binding FinishLine.DimensionsX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="1,0">
                                            <TextBlock Style="{StaticResource MiniLabelStyle}" Text="Y" />
                                            <TextBox FontSize="10" Text="{Binding FinishLine.DimensionsY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Margin="1,0">
                                            <TextBlock Style="{StaticResource MiniLabelStyle}" Text="Z" />
                                            <TextBox FontSize="10" Text="{Binding FinishLine.DimensionsZ, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </UniformGrid>
                                    <StackPanel Margin="1,0">
                                        <TextBlock Style="{StaticResource MiniLabelStyle}" Text="Rotation" />
                                        <TextBox FontSize="10" Text="{Binding FinishLine.RotationHEX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!--  14. START MARKER (IsDrag)  -->
                        <StackPanel Margin="0,0,15,0" Visibility="{Binding IsDrag, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock
                                Margin="0,0,0,8"
                                Style="{StaticResource LabelStyle}"
                                Text="Start Marker" />
                            <Border
                                Height="380"
                                Style="{StaticResource AuthorCardStyle}"
                                Width="380">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBox
                                        FontSize="10"
                                        Grid.Row="0"
                                        IsEnabled="False"
                                        Margin="0,0,0,12"
                                        Text="{Binding StartMarker.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                        <TextBlock
                                            Foreground="{StaticResource TextSecondary}"
                                            Margin="4,0,0,4"
                                            Style="{StaticResource MiniLabelStyle}"
                                            Text="Position" />
                                        <UniformGrid Columns="3">
                                            <StackPanel Margin="1,0">
                                                <TextBlock Style="{StaticResource MiniLabelStyle}" Text="X" />
                                                <TextBox FontSize="10" Text="{Binding StartMarker.PositionX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Margin="1,0">
                                                <TextBlock Style="{StaticResource MiniLabelStyle}" Text="Y" />
                                                <TextBox FontSize="10" Text="{Binding StartMarker.PositionY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Margin="1,0">
                                                <TextBlock Style="{StaticResource MiniLabelStyle}" Text="Z" />
                                                <TextBox FontSize="10" Text="{Binding StartMarker.PositionZ, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </UniformGrid>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Margin="0,12,0,0">
                                        <TextBlock
                                            Margin="4,0,0,2"
                                            Style="{StaticResource MiniLabelStyle}"
                                            Text="Rotation" />
                                        <TextBox FontSize="10" Text="{Binding StartMarker.RotationHEX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!--  15. FINISH MARKER (IsDrag)  -->
                        <StackPanel Margin="0,0,15,0" Visibility="{Binding IsDrag, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock
                                Margin="0,0,0,8"
                                Style="{StaticResource LabelStyle}"
                                Text="Finish Marker" />
                            <Border
                                Height="380"
                                Style="{StaticResource AuthorCardStyle}"
                                Width="380">
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBox
                                        FontSize="10"
                                        Grid.Row="0"
                                        IsEnabled="False"
                                        Margin="0,0,0,12"
                                        Text="{Binding FinishMarker.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                        <TextBlock
                                            Foreground="{StaticResource TextSecondary}"
                                            Margin="4,0,0,4"
                                            Style="{StaticResource MiniLabelStyle}"
                                            Text="Position" />
                                        <UniformGrid Columns="3">
                                            <StackPanel Margin="1,0">
                                                <TextBlock Style="{StaticResource MiniLabelStyle}" Text="X" />
                                                <TextBox FontSize="10" Text="{Binding FinishMarker.PositionX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Margin="1,0">
                                                <TextBlock Style="{StaticResource MiniLabelStyle}" Text="Y" />
                                                <TextBox FontSize="10" Text="{Binding FinishMarker.PositionY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Margin="1,0">
                                                <TextBlock Style="{StaticResource MiniLabelStyle}" Text="Z" />
                                                <TextBox FontSize="10" Text="{Binding FinishMarker.PositionZ, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </UniformGrid>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Margin="0,12,0,0">
                                        <TextBlock
                                            Margin="4,0,0,2"
                                            Style="{StaticResource MiniLabelStyle}"
                                            Text="Rotation" />
                                        <TextBox FontSize="10" Text="{Binding FinishMarker.RotationHEX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>