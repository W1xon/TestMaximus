<Page
    Background="Transparent"
    Title="About Maximus"
    mc:Ignorable="d"
    x:Class="Maximus.Views.AboutAuthorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Page.Resources>
        <Style TargetType="Border" x:Key="AuthorCardStyle">
            <Setter Property="Background" Value="{StaticResource BackgroundMedium}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="15" />
            <Setter Property="Margin" Value="10" />
        </Style>

        <Style TargetType="Button" x:Key="SocialKbdButtonStyle">
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="Background" Value="{StaticResource BackgroundDark}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            x:Name="border">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource AccentColor}" />
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="30">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="220" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" VerticalAlignment="Top">
            <Border Style="{StaticResource AuthorCardStyle}">
                <StackPanel>
                    <TextBlock
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="{StaticResource AccentColor}"
                        HorizontalAlignment="Center"
                        Text="WIXON" />
                    <TextBlock
                        FontSize="10"
                        Foreground="{StaticResource TextTertiary}"
                        HorizontalAlignment="Center"
                        Margin="0,2,0,15"
                        Text="Lead Developer" />

                    <Button
                        Click="SocialButton_Click"
                        Style="{StaticResource SocialKbdButtonStyle}"
                        Tag="https://t.me/CoderW0rker">
                        <TextBlock
                            FontFamily="Consolas"
                            FontSize="10"
                            Text="[ TELEGRAM ]" />
                    </Button>
                    <Button
                        Click="SocialButton_Click"
                        Style="{StaticResource SocialKbdButtonStyle}"
                        Tag="https://github.com/W1xon">
                        <TextBlock
                            FontFamily="Consolas"
                            FontSize="10"
                            Text="[ GITHUB ]" />
                    </Button>
                    <Button
                        Click="SocialButton_Click"
                        Style="{StaticResource SocialKbdButtonStyle}"
                        Tag="https://www.youtube.com/@w_ixon">
                        <TextBlock
                            FontFamily="Consolas"
                            FontSize="10"
                            Text="[ YOUTUBE ]" />
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Hidden">
            <StackPanel Margin="40,0">
                <Border
                    BorderBrush="{StaticResource AccentColor}"
                    BorderThickness="0,0,0,2"
                    Margin="0,0,0,30"
                    Padding="0,0,0,10">
                    <TextBlock
                        FontSize="42"
                        FontWeight="Black"
                        Foreground="{StaticResource TextPrimary}"
                        HorizontalAlignment="Center"
                        Text="MAXIMUS" />
                </Border>

                <TextBlock
                    FontSize="14"
                    Foreground="{StaticResource TextSecondary}"
                    LineHeight="22"
                    TextAlignment="Center"
                    TextWrapping="Wrap">
                    <Run Text="I'm " />
                    <Run
                        FontWeight="Bold"
                        Foreground="{StaticResource AccentColor}"
                        Text="Wixon" />
                    ,<Run Text="the developer behind the technical core of this project. What began as a tool to support a friend's vision evolved into a professional modding environment." />
                    <LineBreak /><LineBreak />
                    <Run
                        FontWeight="Bold"
                        Foreground="{StaticResource TextPrimary}"
                        Text="Maximus" />
                    <Run Text=" is your ultimate terminal for racing modding, built with precision and C# efficiency." />
                    <LineBreak /><LineBreak />
                    <Run Text="The soul of the project is " />
                    <Run
                        FontWeight="Bold"
                        Foreground="{StaticResource AccentColor}"
                        Text="X" />
                    <Run Text=" — our Lead Modder and chief visionary. His expertise in the modding scene and endless ideas are what keep Maximus pushing the limits of what's possible." />
                </TextBlock>

                <Border
                    Background="{StaticResource BackgroundMedium}"
                    BorderBrush="{StaticResource AccentColor}"
                    BorderThickness="1,4,1,1"
                    CornerRadius="4"
                    Margin="0,50,0,0"
                    Padding="20">
                    <StackPanel>
                        <TextBlock
                            FontWeight="Bold"
                            Foreground="{StaticResource TextPrimary}"
                            HorizontalAlignment="Center"
                            Text="PROJECT MAINTENANCE" />
                        <TextBlock
                            FontSize="11"
                            Foreground="{StaticResource TextTertiary}"
                            HorizontalAlignment="Center"
                            Margin="0,5,0,15"
                            Text="Support the continuous development of Maximus" />
                        <Button
                            Click="DonateButton_Click"
                            Content="SEND DONATION"
                            Height="40"
                            Style="{StaticResource ControlButtonStyle}"
                            Width="180" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Column="2" VerticalAlignment="Top">
            <Border Style="{StaticResource AuthorCardStyle}">
                <StackPanel>
                    <TextBlock
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="{StaticResource AccentColor}"
                        HorizontalAlignment="Center"
                        Text="X" />
                    <TextBlock
                        FontSize="10"
                        Foreground="{StaticResource TextTertiary}"
                        HorizontalAlignment="Center"
                        Margin="0,2,0,15"
                        Text="Lead Modder" />

                    <Button
                        Click="SocialButton_Click"
                        Style="{StaticResource SocialKbdButtonStyle}"
                        Tag="https://t.me/beamka_live">
                        <TextBlock
                            FontFamily="Consolas"
                            FontSize="10"
                            Text="[ TELEGRAM ]" />
                    </Button>
                    <Button
                        Click="SocialButton_Click"
                        Style="{StaticResource SocialKbdButtonStyle}"
                        Tag="https://www.youtube.com/@Beamkago_life">
                        <TextBlock
                            FontFamily="Consolas"
                            FontSize="10"
                            Text="[ YOUTUBE ]" />
                    </Button>
                    <Button
                        Click="SocialButton_Click"
                        Style="{StaticResource SocialKbdButtonStyle}"
                        Tag="https://discord.com">
                        <TextBlock
                            FontFamily="Consolas"
                            FontSize="10"
                            Text="[ DISCORD ]" />
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>