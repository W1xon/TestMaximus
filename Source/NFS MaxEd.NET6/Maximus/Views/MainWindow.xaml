<Window
    AllowsTransparency="True"
    Background="Transparent"
    Height="720"
    MinHeight="500"
    MinWidth="800"
    PreviewKeyDown="MainWindow_OnPreviewKeyDown"
    ResizeMode="CanResize"
    Title="Maximus"
    Width="1250"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    x:Class="Maximus.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Window.Style>
        <Style TargetType="Window">
            <Setter Property="shell:WindowChrome.WindowChrome">
                <Setter.Value>
                    <shell:WindowChrome
                        CaptionHeight="0"
                        CornerRadius="0"
                        GlassFrameThickness="0"
                        ResizeBorderThickness="6" />
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Style>

    <!--  Основная граница окна  -->
    <Border
        Background="{StaticResource BackgroundDark}"
        BorderBrush="{StaticResource BorderColor}"
        BorderThickness="1"
        CornerRadius="10">
        <Grid>
            <!--  Углы  -->
            <Grid.RowDefinitions>
                <RowDefinition Height="45" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Title Bar (Без кнопки Toggle)  -->
            <Border
                Background="{StaticResource BackgroundMedium}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,0,1"
                CornerRadius="10,10,0,0"
                Grid.Row="0"
                MouseLeftButtonDown="DragWindow">
                <Grid>
                    <StackPanel
                        HorizontalAlignment="Left"
                        Margin="15,0,0,0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                        <TextBlock
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="Maximus" />
                    </StackPanel>

                    <!--  System Buttons  -->
                    <StackPanel
                        HorizontalAlignment="Right"
                        Margin="0,0,10,0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                        <Button
                            Click="Minimize_Click"
                            Content="━"
                            Style="{StaticResource WindowButtonStyle}"
                            ToolTip="Minimize" />
                        <Button
                            Click="Maximize_Click"
                            Content="▢"
                            Style="{StaticResource WindowButtonStyle}"
                            ToolTip="Maximize" />
                        <Button
                            Click="Close_Click"
                            Content="×"
                            Style="{StaticResource CloseWindowButtonStyle}"
                            ToolTip="Close" />
                    </StackPanel>
                </Grid>
            </Border>

            <!--  Основной контент  -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  Боковая панель  -->
                <Border
                    Background="{StaticResource BackgroundMedium}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="0,0,1,0"
                    Grid.Column="0"
                    x:Name="NavigationPanel">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  Navigation (Квадратные кнопки-иконки)  -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <StackPanel Margin="10,15,5,15">

                                <!--  Races Icon Button  -->
                                <Button
                                    Click="OnRacesClick"
                                    Height="90"
                                    Margin="0,0,0,10"
                                    Style="{StaticResource NavButtonStyle}"
                                    Width="90"
                                    x:Name="RacesButton">
                                    <StackPanel>
                                        <Image
                                            Height="48"
                                            Margin="0,0,0,5"
                                            Source="pack://application:,,,/Assets/RACE.png"
                                            Stretch="Uniform"
                                            Width="48" />
                                        <TextBlock
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            HorizontalAlignment="Center"
                                            Text="Races" />
                                    </StackPanel>
                                </Button>

                                <!--  Milestones Icon Button  -->
                                <Button
                                    Click="OnMilestonesClick"
                                    Height="90"
                                    Margin="0,0,0,10"
                                    Style="{StaticResource NavButtonStyle}"
                                    Width="90"
                                    x:Name="MilestonesButton">
                                    <StackPanel>
                                        <Image
                                            Height="48"
                                            Margin="0,0,0,5"
                                            Source="pack://application:,,,/Assets/MILESTONE.png"
                                            Stretch="Uniform"
                                            Width="48" />
                                        <TextBlock
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            HorizontalAlignment="Center"
                                            Text="Milestones" />
                                    </StackPanel>
                                </Button>

                                <!--  Blacklist Icon Button  -->
                                <Button
                                    Click="OnBlacklistClick"
                                    Height="90"
                                    Style="{StaticResource NavButtonStyle}"
                                    Width="90"
                                    x:Name="BlacklistButton">
                                    <StackPanel>
                                        <Image
                                            Height="48"
                                            Margin="0,0,0,5"
                                            Source="pack://application:,,,/Assets/BLACKLIST.png"
                                            Stretch="Uniform"
                                            Width="48" />
                                        <TextBlock
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            HorizontalAlignment="Center"
                                            Text="Blacklist" />
                                    </StackPanel>
                                </Button>

                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="5,15,10,15">

                                <!--  Races Icon Button  -->
                                <Button
                                    Click="OnRacesClick"
                                    Height="90"
                                    Margin="0,0,0,10"
                                    Style="{StaticResource NavButtonStyle}"
                                    Width="90">
                                    <StackPanel>
                                        <Image
                                            Height="48"
                                            Margin="0,0,0,5"
                                            Source="pack://application:,,,/Assets/POLICE_PARAMETRS.png"
                                            Stretch="Uniform"
                                            Width="48" />
                                        <TextBlock
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            HorizontalAlignment="Center"
                                            Text="Police" />
                                    </StackPanel>
                                </Button>

                                <!--  Engage Icon Button  -->
                                <Button
                                    Click="OnEngageClick"
                                    Height="90"
                                    Margin="0,0,0,10"
                                    Style="{StaticResource NavButtonStyle}"
                                    Width="90"
                                    x:Name="EngageButton">
                                    <StackPanel>
                                        <Image
                                            Height="48"
                                            Margin="0,0,0,5"
                                            Source="pack://application:,,,/Assets/ENGAGE.png"
                                            Stretch="Uniform"
                                            Width="48" />
                                        <TextBlock
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            HorizontalAlignment="Center"
                                            Text="Engage" />
                                    </StackPanel>
                                </Button>

                                <!--  Leaders Icon Button  -->
                                <Button
                                    Click="OnLeadersClick"
                                    Height="90"
                                    Style="{StaticResource NavButtonStyle}"
                                    Width="90"
                                    x:Name="LeadersButton">
                                    <StackPanel>
                                        <Image
                                            Height="48"
                                            Margin="0,0,0,5"
                                            Source="pack://application:,,,/Assets/LEADERBOARD.png"
                                            Stretch="Uniform"
                                            Width="48" />
                                        <TextBlock
                                            FontSize="11"
                                            FontWeight="SemiBold"
                                            HorizontalAlignment="Center"
                                            Text="Leaders" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!--  Нижняя секция с кнопками действий  -->
                        <StackPanel
                            Grid.Row="1"
                            Margin="15,20,15,0"
                            VerticalAlignment="Bottom">
                            <Separator
                                Background="{StaticResource BorderColor}"
                                Height="2"
                                Margin="0,10,0,10" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <!--  About Author  -->
                                <Button
                                    Click="OnAboutAuthorClick"
                                    Content="About Author"
                                    Grid.Column="0"
                                    Height="80"
                                    Style="{StaticResource ButtonStyle}"
                                    Width="80" />

                                <!--  Кнопка Save  -->
                                <Button
                                    Click="OnGenerateClick"
                                    Content="Save"
                                    Grid.Column="1"
                                    Height="80"
                                    Style="{StaticResource ButtonStyle}"
                                    Width="80"
                                    x:Name="SaveButton" />
                            </Grid>


                            <StackPanel>
                                <Button
                                    AllowDrop="True"
                                    Click="OpenScript_Click"
                                    DragEnter="DropZone_DragEnter"
                                    DragLeave="DropZone_DragLeave"
                                    Drop="UIElement_OnDrop"
                                    Height="120"
                                    Margin="10,10,10,5"
                                    Style="{StaticResource DropZoneButtonStyle}">

                                    <StackPanel Orientation="Vertical">
                                        <TextBlock
                                            FontSize="32"
                                            HorizontalAlignment="Center"
                                            Margin="0,0,0,8"
                                            Opacity="0.5"
                                            Text="📂" />
                                        <TextBlock
                                            FontWeight="Bold"
                                            Foreground="{StaticResource TextPrimary}"
                                            HorizontalAlignment="Center"
                                            Text="Drop .nfsms script here" />
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="{StaticResource TextTertiary}"
                                            HorizontalAlignment="Center"
                                            Margin="0,4,0,0"
                                            Text="or click to browse files" />
                                    </StackPanel>
                                </Button>

                                <StackPanel
                                    HorizontalAlignment="Center"
                                    Margin="0,10,0,0"
                                    Opacity="0.6">
                                    <!--  Подсказка Paste  -->
                                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="{StaticResource TextTertiary}"
                                            Text="Press"
                                            VerticalAlignment="Center" />
                                        <Border
                                            Background="{StaticResource BackgroundLight}"
                                            CornerRadius="3"
                                            Margin="4,0"
                                            Padding="4,1"
                                            VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="9"
                                                FontWeight="Bold"
                                                Foreground="{StaticResource AccentColor}"
                                                Text="Ctrl + Shift + V" />
                                        </Border>
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="{StaticResource TextTertiary}"
                                            Text="to paste from clipboard"
                                            VerticalAlignment="Center" />
                                    </StackPanel>

                                    <!--  Подсказка Open  -->
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        Margin="0,4,0,0"
                                        Orientation="Horizontal">
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="{StaticResource TextTertiary}"
                                            Text="Press"
                                            VerticalAlignment="Center" />
                                        <Border
                                            Background="{StaticResource BackgroundLight}"
                                            CornerRadius="3"
                                            Margin="4,0"
                                            Padding="4,1"
                                            VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="9"
                                                FontWeight="Bold"
                                                Foreground="{StaticResource AccentColor}"
                                                Text="Ctrl + O" />
                                        </Border>
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="{StaticResource TextTertiary}"
                                            Text="to open script"
                                            VerticalAlignment="Center" />
                                    </StackPanel>

                                    <!--  Подсказка Save  -->
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        Margin="0,4,0,0"
                                        Orientation="Horizontal">
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="{StaticResource TextTertiary}"
                                            Text="Press"
                                            VerticalAlignment="Center" />
                                        <Border
                                            Background="{StaticResource BackgroundLight}"
                                            CornerRadius="3"
                                            Margin="4,0"
                                            Padding="4,1"
                                            VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="9"
                                                FontWeight="Bold"
                                                Foreground="{StaticResource AccentColor}"
                                                Text="Ctrl + S" />
                                        </Border>
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="{StaticResource TextTertiary}"
                                            Text="to save script"
                                            VerticalAlignment="Center" />
                                    </StackPanel>

                                    <!--  Подсказка Preview  -->
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        Margin="0,4,0,0"
                                        Orientation="Horizontal">
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="{StaticResource TextTertiary}"
                                            Text="Press"
                                            VerticalAlignment="Center" />
                                        <Border
                                            Background="{StaticResource BackgroundLight}"
                                            CornerRadius="3"
                                            Margin="4,0"
                                            Padding="4,1"
                                            VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="9"
                                                FontWeight="Bold"
                                                Foreground="{StaticResource AccentColor}"
                                                Text="Ctrl + P" />
                                        </Border>
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="{StaticResource TextTertiary}"
                                            Text="to preview"
                                            VerticalAlignment="Center" />
                                    </StackPanel>

                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid
                    Background="{StaticResource BackgroundDark}"
                    ClipToBounds="True"
                    Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <!--  Blueprint сетка  -->
                        <Rectangle>
                            <Rectangle.Fill>
                                <DrawingBrush
                                    Opacity="0.06"
                                    TileMode="Tile"
                                    Viewport="0,0,80,80"
                                    ViewportUnits="Absolute">
                                    <DrawingBrush.Drawing>
                                        <DrawingGroup>
                                            <GeometryDrawing>
                                                <GeometryDrawing.Pen>
                                                    <Pen Brush="White" Thickness="0.35" />
                                                </GeometryDrawing.Pen>
                                                <GeometryDrawing.Geometry>
                                                    <GeometryGroup>
                                                        <LineGeometry EndPoint="20,80" StartPoint="20,0" />
                                                        <LineGeometry EndPoint="40,80" StartPoint="40,0" />
                                                        <LineGeometry EndPoint="60,80" StartPoint="60,0" />
                                                        <LineGeometry EndPoint="80,20" StartPoint="0,20" />
                                                        <LineGeometry EndPoint="80,40" StartPoint="0,40" />
                                                        <LineGeometry EndPoint="80,60" StartPoint="0,60" />
                                                    </GeometryGroup>
                                                </GeometryDrawing.Geometry>
                                            </GeometryDrawing>
                                            <GeometryDrawing>
                                                <GeometryDrawing.Pen>
                                                    <Pen Brush="White" Thickness="0.9" />
                                                </GeometryDrawing.Pen>
                                                <GeometryDrawing.Geometry>
                                                    <GeometryGroup>
                                                        <LineGeometry EndPoint="80,0" StartPoint="0,0" />
                                                        <LineGeometry EndPoint="0,80" StartPoint="0,0" />
                                                    </GeometryGroup>
                                                </GeometryDrawing.Geometry>
                                            </GeometryDrawing>
                                        </DrawingGroup>
                                    </DrawingBrush.Drawing>
                                </DrawingBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                        <Frame
                            Background="Transparent"
                            NavigationUIVisibility="Hidden"
                            x:Name="MainFrame" />
                    </Grid>

                    <Border
                        Background="#1E1E1E"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1,0,0,0"
                        Grid.Column="1"
                        Width="0"
                        x:Name="PreviewBorder">
                        <RichTextBox
                            Background="Transparent"
                            BorderThickness="0"
                            FontFamily="Consolas"
                            FontSize="11"
                            Foreground="#D4D4D4"
                            IsReadOnly="True"
                            Padding="15"
                            VerticalScrollBarVisibility="Auto"
                            x:Name="PreviewRichTextBox" />
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>