<Window
    AllowsTransparency="True"
    Background="Transparent"
    Height="720"
    PreviewKeyDown="MainWindow_OnPreviewKeyDown"
    Title="Maximus"
    Width="1250"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    x:Class="Maximus.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:views="clr-namespace:Maximus.Views"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  Основная граница окна  -->
    <Border
        Background="{StaticResource BackgroundDark}"
        BorderBrush="{StaticResource BorderColor}"
        BorderThickness="1"
        CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="45" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Title Bar (Без кнопки Toggle)  -->
            <Border
                Background="{StaticResource BackgroundMedium}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,0,1"
                CornerRadius="10,10,0,0"
                Grid.Row="0"
                MouseLeftButtonDown="DragWindow">
                <Grid>
                    <StackPanel
                        HorizontalAlignment="Left"
                        Margin="15,0,0,0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                        <TextBlock
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="Maximus" />
                    </StackPanel>

                    <!--  System Buttons  -->
                    <StackPanel
                        HorizontalAlignment="Right"
                        Margin="0,0,10,0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                        <Button
                            Click="Minimize_Click"
                            Content="━"
                            Style="{StaticResource WindowButtonStyle}"
                            ToolTip="Minimize" />
                        <Button
                            Click="Maximize_Click"
                            Content="▢"
                            Style="{StaticResource WindowButtonStyle}"
                            ToolTip="Maximize" />
                        <Button
                            Click="Close_Click"
                            Content="×"
                            Style="{StaticResource CloseWindowButtonStyle}"
                            ToolTip="Close" />
                    </StackPanel>
                </Grid>
            </Border>

            <!--  Основной контент  -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  Боковая панель  -->
                <Border
                    Background="{StaticResource BackgroundMedium}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="0,0,1,0"
                    Grid.Column="0"
                    x:Name="LeftPanel">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  Navigation (Квадратные кнопки-иконки)  -->
                        <ScrollViewer
                            Grid.Row="0"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="10,15,5,15">

                                    <!--  Races Icon Button  -->
                                    <Button
                                        Click="OnRacesClick"
                                        Height="90"
                                        Margin="0,0,0,10"
                                        Style="{StaticResource NavButtonStyle}"
                                        Width="90">
                                        <StackPanel>
                                            <Image
                                                Height="48"
                                                Margin="0,0,0,5"
                                                Source="pack://application:,,,/Assets/RACE.png"
                                                Stretch="Uniform"
                                                Width="48" />
                                            <TextBlock
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                HorizontalAlignment="Center"
                                                Text="Races" />
                                        </StackPanel>
                                    </Button>

                                    <!--  Milestones Icon Button  -->
                                    <Button
                                        Click="OnMilestonesClick"
                                        Height="90"
                                        Margin="0,0,0,10"
                                        Style="{StaticResource NavButtonStyle}"
                                        Width="90">
                                        <StackPanel>
                                            <Image
                                                Height="48"
                                                Margin="0,0,0,5"
                                                Source="pack://application:,,,/Assets/MILESTONE.png"
                                                Stretch="Uniform"
                                                Width="48" />
                                            <TextBlock
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                HorizontalAlignment="Center"
                                                Text="Milestones" />
                                        </StackPanel>
                                    </Button>

                                    <!--  Blacklist Icon Button  -->
                                    <Button
                                        Click="OnBlacklistClick"
                                        Height="90"
                                        Style="{StaticResource NavButtonStyle}"
                                        Width="90">
                                        <StackPanel>
                                            <Image
                                                Height="48"
                                                Margin="0,0,0,5"
                                                Source="pack://application:,,,/Assets/BLACKLIST.png"
                                                Stretch="Uniform"
                                                Width="48" />
                                            <TextBlock
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                HorizontalAlignment="Center"
                                                Text="Blacklist" />
                                        </StackPanel>
                                    </Button>

                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="5,15,10,15">

                                    <!--  Races Icon Button  -->
                                    <Button
                                        Click="OnRacesClick"
                                        Height="90"
                                        Margin="0,0,0,10"
                                        Style="{StaticResource NavButtonStyle}"
                                        Width="90">
                                        <StackPanel>
                                            <Image
                                                Height="48"
                                                Margin="0,0,0,5"
                                                Source="pack://application:,,,/Assets/POLICE_PARAMETRS.png"
                                                Stretch="Uniform"
                                                Width="48" />
                                            <TextBlock
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                HorizontalAlignment="Center"
                                                Text="Police" />
                                        </StackPanel>
                                    </Button>

                                    <!--  Milestones Icon Button  -->
                                    <Button
                                        Click="OnMilestonesClick"
                                        Height="90"
                                        Margin="0,0,0,10"
                                        Style="{StaticResource NavButtonStyle}"
                                        Width="90">
                                        <StackPanel>
                                            <Image
                                                Height="48"
                                                Margin="0,0,0,5"
                                                Source="pack://application:,,,/Assets/ENGAGE.png"
                                                Stretch="Uniform"
                                                Width="48" />
                                            <TextBlock
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                HorizontalAlignment="Center"
                                                Text="ENGAGE" />
                                        </StackPanel>
                                    </Button>

                                    <!--  Blacklist Icon Button  -->
                                    <Button
                                        Click="OnBlacklistClick"
                                        Height="90"
                                        Style="{StaticResource NavButtonStyle}"
                                        Width="90">
                                        <StackPanel>
                                            <Image
                                                Height="48"
                                                Margin="0,0,0,5"
                                                Source="pack://application:,,,/Assets/LEADERBOARD.png"
                                                Stretch="Uniform"
                                                Width="48" />
                                            <TextBlock
                                                FontSize="11"
                                                FontWeight="SemiBold"
                                                HorizontalAlignment="Center"
                                                Text="Leaders" />
                                        </StackPanel>
                                    </Button>

                                </StackPanel>
                            </Grid>

                        </ScrollViewer>

                        <!--  Нижняя секция с кнопками действий  -->
                        <StackPanel Grid.Row="2" Margin="15,0,15,20">
                            <!--  Разделитель  -->
                            <Separator Margin="0,0,0,15" />

                            <!--  About Author  -->
                            <Button
                                Click="OnAboutAuthorClick"
                                Content="About"
                                Margin="0,0,0,12"
                                Style="{StaticResource NavButtonStyle}" />

                            <!--  Кнопка Save  -->
                            <Button
                                Click="OnGenerateClick"
                                Height="45"
                                Style="{StaticResource ButtonStyle}">
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">

                                    <TextBlock
                                        FontWeight="Bold"
                                        Text="Save Project"
                                        VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <StackPanel>
                                <Button
                                    AllowDrop="True"
                                    Click="OpenScript_Click"
                                    DragEnter="DropZone_DragEnter"
                                    DragLeave="DropZone_DragLeave"
                                    Drop="UIElement_OnDrop"
                                    Height="120"
                                    Margin="10,10,10,5"
                                    Style="{StaticResource DropZoneButtonStyle}">

                                    <StackPanel Orientation="Vertical">
                                        <TextBlock
                                            FontSize="32"
                                            HorizontalAlignment="Center"
                                            Margin="0,0,0,8"
                                            Opacity="0.5"
                                            Text="📂" />
                                        <TextBlock
                                            FontWeight="Bold"
                                            Foreground="{StaticResource TextPrimary}"
                                            HorizontalAlignment="Center"
                                            Text="Drop .nfsms script here" />
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="{StaticResource TextTertiary}"
                                            HorizontalAlignment="Center"
                                            Margin="0,4,0,0"
                                            Text="or click to browse files" />
                                    </StackPanel>
                                </Button>

                                <StackPanel
                                    HorizontalAlignment="Center"
                                    Margin="0,10,0,0"
                                    Opacity="0.6">
                                    <!--  Подсказка Paste  -->
                                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="{StaticResource TextTertiary}"
                                            Text="Press"
                                            VerticalAlignment="Center" />
                                        <Border
                                            Background="{StaticResource BackgroundLight}"
                                            CornerRadius="3"
                                            Margin="4,0"
                                            Padding="4,1"
                                            VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="9"
                                                FontWeight="Bold"
                                                Foreground="{StaticResource AccentColor}"
                                                Text="Ctrl + Shift + V" />
                                        </Border>
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="{StaticResource TextTertiary}"
                                            Text="to paste from clipboard"
                                            VerticalAlignment="Center" />
                                    </StackPanel>

                                    <!--  Подсказка Save  -->
                                    <StackPanel
                                        HorizontalAlignment="Center"
                                        Margin="0,4,0,0"
                                        Orientation="Horizontal">
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="{StaticResource TextTertiary}"
                                            Text="Press"
                                            VerticalAlignment="Center" />
                                        <Border
                                            Background="{StaticResource BackgroundLight}"
                                            CornerRadius="3"
                                            Margin="4,0"
                                            Padding="4,1"
                                            VerticalAlignment="Center">
                                            <TextBlock
                                                FontSize="9"
                                                FontWeight="Bold"
                                                Foreground="{StaticResource AccentColor}"
                                                Text="Ctrl + S" />
                                        </Border>
                                        <TextBlock
                                            FontSize="10"
                                            Foreground="{StaticResource TextTertiary}"
                                            Text="to save script"
                                            VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid
                    Background="{StaticResource BackgroundDark}"
                    ClipToBounds="True"
                    Grid.Column="1">
                    <views:DynamicBackground />
                    <Frame
                        Background="Transparent"
                        NavigationUIVisibility="Hidden"
                        x:Name="MainFrame" />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>