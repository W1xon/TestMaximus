<Window
    AllowsTransparency="True"
    Background="Transparent"
    Height="520"
    Title="Map Viewer"
    Width="1080"
    WindowStartupLocation="CenterOwner"
    WindowStyle="None"
    mc:Ignorable="d"
    x:Class="Maximus.Views.MapWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border
        Background="{StaticResource BackgroundDark}"
        BorderBrush="{StaticResource BorderColor}"
        BorderThickness="1"
        CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                Background="{StaticResource BackgroundMedium}"
                CornerRadius="8,8,0,0"
                Grid.Row="0"
                MouseLeftButtonDown="DragWindow">
                <Grid>
                    <TextBlock
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource AccentSecondary}"
                        Margin="20,0"
                        Text="Map Viewer"
                        VerticalAlignment="Center" />
                    <StackPanel
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                        <Button
                            Click="Minimize_Click"
                            Content="-"
                            Style="{StaticResource WindowButtonStyle}" />
                        <Button
                            Click="Close_Click"
                            Content="×"
                            Style="{StaticResource CloseWindowButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Border
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    ClipToBounds="True"
                    CornerRadius="6"
                    Margin="10">
                    <ScrollViewer
                        Background="{StaticResource BackgroundDark}"
                        HorizontalScrollBarVisibility="Auto"
                        PreviewMouseWheel="MapCanvas_MouseWheel"
                        VerticalScrollBarVisibility="Auto"
                        x:Name="MapScrollViewer">

                        <Grid
                            Background="Transparent"
                            MouseLeftButtonDown="MapCanvas_MouseLeftButtonDown"
                            MouseLeftButtonUp="MapCanvas_MouseLeftButtonUp"
                            MouseMove="MapCanvas_MouseMove"
                            x:Name="ContentGrid">
                            <Image
                                RenderOptions.BitmapScalingMode="HighQuality"
                                Source="pack://application:,,,/Maximus;component/Assets/map.png"
                                Stretch="None"
                                x:Name="MapImage">
                                <Image.LayoutTransform>
                                    <ScaleTransform x:Name="ScaleTransform" />
                                </Image.LayoutTransform>
                            </Image>
                        </Grid>
                    </ScrollViewer>
                </Border>

                <StackPanel
                    HorizontalAlignment="Right"
                    Margin="20"
                    VerticalAlignment="Bottom">
                    <Border Style="{StaticResource PanelStyle}">
                        <StackPanel>
                            <Button
                                Click="ZoomIn_Click"
                                Content="+"
                                FontSize="20"
                                Style="{StaticResource ControlButtonStyle}" />
                            <Button
                                Click="ZoomOut_Click"
                                Content="-"
                                FontSize="20"
                                Style="{StaticResource ControlButtonStyle}" />
                            <Button
                                Click="ResetZoom_Click"
                                Content="Reset"
                                Style="{StaticResource ControlButtonStyle}" />
                        </StackPanel>
                    </Border>
                    <Border
                        Margin="0,10,0,0"
                        Padding="12,8"
                        Style="{StaticResource PanelStyle}">
                        <TextBlock
                            HorizontalAlignment="Center"
                            Style="{StaticResource CaptionStyle}"
                            Text="Zoom: 100%"
                            x:Name="ZoomLabel" />
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>