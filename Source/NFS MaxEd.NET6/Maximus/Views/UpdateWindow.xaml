<Window
    AllowsTransparency="True"
    Background="Transparent"
    Height="500"
    ResizeMode="NoResize"
    Title="Обновление Maximus"
    Width="860"
    WindowStyle="None"
    mc:Ignorable="d"
    x:Class="Maximus.Views.UpdateWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Maximus.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border
        Background="{StaticResource BackgroundDark}"
        BorderBrush="{StaticResource BorderColor}"
        BorderThickness="1"
        CornerRadius="16">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="24"
                Color="Black"
                Opacity="0.35"
                ShadowDepth="0" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!--  Title Bar  -->
                <RowDefinition Height="*" />
                <!--  Content  -->
            </Grid.RowDefinitions>

            <!--  Title Bar  -->
            <Grid
                Background="Transparent"
                Grid.Row="0"
                Height="40">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextTertiary}"
                    IsHitTestVisible="False"
                    Margin="16,0"
                    Style="{StaticResource CaptionStyle}"
                    Text="Обновление доступно"
                    VerticalAlignment="Center" />

                <StackPanel
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">

                    <TextBlock
                        Cursor="Help"
                        Foreground="{StaticResource TextSecondary}"
                        Margin="0,0,12,0"
                        Text="?"
                        ToolTipService.Placement="Bottom"
                        VerticalAlignment="Center">
                        <TextBlock.ToolTip>
                            <TextBlock
                                MaxWidth="280"
                                Text="Обновление загрузит и установит новую версию. Во время процесса не закрывайте окно."
                                TextWrapping="Wrap" />
                        </TextBlock.ToolTip>
                    </TextBlock>

                    <Button
                        Click="CloseBtn_Click"
                        Content="×"
                        Style="{StaticResource CloseWindowButtonStyle}" />
                </StackPanel>
            </Grid>

            <!--  Content Area  -->
            <Border
                Background="{StaticResource BackgroundMedium}"
                CornerRadius="0,0,15,15"
                Grid.Row="1"
                Padding="24,20,24,20">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <!--  Version  -->
                        <RowDefinition Height="Auto" />
                        <!--  Date  -->
                        <RowDefinition Height="Auto" />
                        <!--  Warning  -->
                        <RowDefinition Height="*" />
                        <!--  Changelog  -->
                        <RowDefinition Height="88" />
                        <!--  Progress  -->
                        <RowDefinition Height="Auto" />
                        <!--  Buttons  -->
                    </Grid.RowDefinitions>

                    <!--  Version Info  -->
                    <TextBlock
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="{StaticResource TextPrimary}"
                        Grid.Row="0"
                        Margin="0,0,0,8"
                        Text="Версия 1.0.0"
                        x:Name="VersionText" />

                    <!--  Release Date  -->
                    <TextBlock
                        Foreground="{StaticResource TextSecondary}"
                        Grid.Row="1"
                        Margin="0,0,0,20"
                        Style="{StaticResource BodyStyle}"
                        Text="Выпуск: 2026-02-15"
                        x:Name="DateText" />

                    <!--  Mandatory Warning  -->
                    <Border
                        Background="#1AE81123"
                        BorderBrush="{StaticResource DeleteColor}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Grid.Row="2"
                        Margin="0,0,0,16"
                        Padding="12"
                        Visibility="Collapsed"
                        x:Name="MandatoryWarning">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                FontSize="16"
                                Foreground="{StaticResource DeleteColor}"
                                Grid.Column="0"
                                Margin="0,2,10,0"
                                Text="?"
                                VerticalAlignment="Top" />

                            <TextBlock
                                FontWeight="SemiBold"
                                Foreground="{StaticResource DeleteColor}"
                                Grid.Column="1"
                                LineHeight="20"
                                Style="{StaticResource BodyStyle}"
                                Text="Обязательное обновление — приложение не может работать без него"
                                TextWrapping="Wrap"
                                VerticalAlignment="Center"
                                x:Name="MandatoryText" />
                        </Grid>
                    </Border>

                    <!--  Changelog  -->
                    <Border
                        Background="{StaticResource BackgroundLight}"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Grid.Row="3"
                        Margin="0,0,0,16"
                        Padding="16">

                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">

                            <StackPanel>
                                <TextBlock
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource AccentSecondary}"
                                    Margin="0,0,0,12"
                                    Style="{StaticResource BodyStyle}"
                                    Text="Что нового:" />

                                <ItemsControl ItemsSource="{Binding}" x:Name="ChangelogList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock
                                                    Foreground="{StaticResource AccentSecondary}"
                                                    Grid.Column="0"
                                                    Margin="0,0,8,0"
                                                    Style="{StaticResource BodyStyle}"
                                                    Text="•"
                                                    VerticalAlignment="Top" />

                                                <TextBlock
                                                    Foreground="{StaticResource TextSecondary}"
                                                    Grid.Column="1"
                                                    LineHeight="20"
                                                    Style="{StaticResource BodyStyle}"
                                                    Text="{Binding}"
                                                    TextWrapping="Wrap" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!--  Progress Bar  -->
                    <Border
                        Background="{StaticResource BackgroundLight}"
                        BorderBrush="{StaticResource BorderColor}"
                        BorderThickness="1"
                        CornerRadius="6"
                        Grid.Row="4"
                        Margin="0,0,0,16"
                        MinHeight="60"
                        Padding="12"
                        Visibility="Collapsed"
                        x:Name="ProgressContainer">
                        <StackPanel>
                            <TextBlock
                                Foreground="{StaticResource TextSecondary}"
                                Margin="0,0,0,8"
                                Style="{StaticResource BodyStyle}"
                                Text="Загрузка обновления..."
                                x:Name="ProgressText" />

                            <ProgressBar
                                Background="{StaticResource BackgroundMedium}"
                                BorderThickness="0"
                                Foreground="#42A5F5"
                                Height="8"
                                IsIndeterminate="True"
                                Style="{x:Null}"
                                x:Name="DownloadProgress" />
                        </StackPanel>
                    </Border>

                    <!--  Buttons  -->
                    <Grid Grid.Row="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button
                            Click="SkipButton_Click"
                            Content="Пропустить"
                            Grid.Column="0"
                            Height="40"
                            HorizontalAlignment="Left"
                            Opacity="0.7"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="120"
                            x:Name="SkipButton" />

                        <Button
                            Click="UpdateButton_Click"
                            Content="Обновить"
                            Grid.Column="1"
                            Height="40"
                            Style="{StaticResource ButtonStyle}"
                            Width="140"
                            x:Name="UpdateButton" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
