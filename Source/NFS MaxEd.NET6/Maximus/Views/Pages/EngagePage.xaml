<Page
    Background="Transparent"
    Title="EngagePage"
    mc:Ignorable="d"
    x:Class="Maximus.Views.EngagePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Maximus.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Page.Resources>
        <VisualBrush
            Stretch="Uniform"
            TileMode="Tile"
            Viewport="0,0,30,30"
            ViewportUnits="Absolute"
            x:Key="ArrowTileBrush">
            <VisualBrush.Visual>
                <Image Source="pack://application:,,,/Assets/STRELKA.png" Width="30">
                    <Image.RenderTransform>
                        <ScaleTransform CenterX="15" ScaleX="-1" />
                    </Image.RenderTransform>
                </Image>
            </VisualBrush.Visual>
        </VisualBrush>

        <Style TargetType="Grid" x:Key="CardGridStyle">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Page.Resources>

    <Grid VerticalAlignment="Center">
        <StackPanel>
            <Border Margin="20" Style="{StaticResource CardStyle}">
                <Grid Style="{StaticResource CardGridStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ComboBox
                        ItemsSource="{Binding EngageConfig.EngageTypes}"
                        Margin="0,5"
                        SelectedItem="{Binding EngageConfig.EngageType}"
                        SelectionChanged="Selector_OnSelectionChanged"
                        x:Name="EngageComboBox" />

                    <Rectangle
                        Fill="{StaticResource ArrowTileBrush}"
                        Grid.Column="1"
                        Height="30"
                        Margin="10,0"
                        Width="150" />
                    <TextBox
                        Grid.Column="2"
                        Margin="5"
                        VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Border
                Margin="20"
                Style="{StaticResource CardStyle}"
                Visibility="{Binding EngageConfig.IsEngageEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid Style="{StaticResource CardGridStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="Bounty" />
                        <TextBox Text="{Binding EngageConfig.Engage.Bounty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,15,0">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="ThresholdSpeed" />
                        <TextBox Text="{Binding EngageConfig.Engage.ThresholdSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,15,0">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="SpawnPoint" />
                        <TextBox Text="{Binding EngageConfig.Engage.SpawnPoint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="0,0,15,0">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="SpawnPoint" />
                        <ComboBox ItemsSource="{Binding EngageConfig.RaceBins}" SelectedItem="{Binding EngageConfig.RaceBin}" />
                    </StackPanel>
                    <StackPanel Grid.Column="4" Orientation="Horizontal">
                        <StackPanel Margin="0,0,5,0">
                            <TextBlock Style="{StaticResource LabelStyle}" Text="X" />
                            <TextBox Text="{Binding EngageConfig.Engage.Point.X, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="50" />
                        </StackPanel>
                        <StackPanel Margin="0,0,5,0">
                            <TextBlock Style="{StaticResource LabelStyle}" Text="Y" />
                            <TextBox Text="{Binding EngageConfig.Engage.Point.Y, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="50" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Style="{StaticResource LabelStyle}" Text="Z" />
                            <TextBox Text="{Binding EngageConfig.Engage.Point.Z, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="50" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
            <Border
                Margin="20"
                Style="{StaticResource CardStyle}"
                Visibility="{Binding EngageConfig.IsZoneEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid Style="{StaticResource CardGridStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="BinIndex" />
                        <TextBox Text="{Binding EngageConfig.BinIndex.BinIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,15,0">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="Radius" />
                        <TextBox Text="{Binding EngageConfig.Zone.Radius, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <StackPanel Margin="0,0,5,0">
                            <TextBlock Style="{StaticResource LabelStyle}" Text="X" />
                            <TextBox Text="{Binding EngageConfig.Zone.Point.X, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="50" />
                        </StackPanel>
                        <StackPanel Margin="0,0,5,0">
                            <TextBlock Style="{StaticResource LabelStyle}" Text="Y" />
                            <TextBox Text="{Binding EngageConfig.Zone.Point.Y, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="50" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Style="{StaticResource LabelStyle}" Text="Z" />
                            <TextBox Text="{Binding EngageConfig.Zone.Point.Z, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="50" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
            <Border
                Margin="20"
                Style="{StaticResource CardStyle}"
                Visibility="{Binding EngageConfig.IsSpeedtrapEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid Style="{StaticResource CardGridStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="Bounty" />
                        <TextBox Text="{Binding EngageConfig.Speedtrap.Bounty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,15,0">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="ThresholdSpeed" />
                        <TextBox Text="{Binding EngageConfig.Speedtrap.ThresholdSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,15,0">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="SpawnPoint" />
                        <TextBox Text="{Binding EngageConfig.Speedtrap.SpawnPoint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="0,0,15,0">
                        <TextBlock Style="{StaticResource LabelStyle}" Text="SpawnPoint" />
                        <ComboBox ItemsSource="{Binding EngageConfig.RaceBins}" SelectedItem="{Binding EngageConfig.RaceBin}" />
                    </StackPanel>
                    <StackPanel Grid.Column="4" Orientation="Horizontal">
                        <StackPanel Margin="0,0,5,0">
                            <TextBlock Style="{StaticResource LabelStyle}" Text="X" />
                            <TextBox Text="{Binding EngageConfig.Speedtrap.Point.X, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="50" />
                        </StackPanel>
                        <StackPanel Margin="0,0,5,0">
                            <TextBlock Style="{StaticResource LabelStyle}" Text="Y" />
                            <TextBox Text="{Binding EngageConfig.Speedtrap.Point.Y, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="50" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Style="{StaticResource LabelStyle}" Text="Z" />
                            <TextBox Text="{Binding EngageConfig.Speedtrap.Point.Z, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="50" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </Grid>
</Page>
