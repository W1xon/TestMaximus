<Page
    Background="Transparent"
    Title="MilestonesPage"
    mc:Ignorable="d"
    x:Class="Maximus.Views.MilestonesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20" VerticalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Main Content  -->
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Basic Information Section  -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                <StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!--  Milestone Type  -->
                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <TextBlock
                                Margin="0,0,0,5"
                                Style="{StaticResource LabelStyle}"
                                Text="Milestone Type" />
                            <ComboBox ItemsSource="{Binding MilestoneConfig.MilestoneTypes}" SelectedItem="{Binding MilestoneConfig.MilestoneType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <!--  Spawn Point  -->
                        <StackPanel Grid.Column="1" Margin="0,0,15,0">
                            <TextBlock
                                Margin="0,0,0,5"
                                Style="{StaticResource LabelStyle}"
                                Text="Spawn Point" />
                            <ComboBox ItemsSource="{Binding MilestoneConfig.SpawnPoints}" SelectedItem="{Binding MilestoneConfig.SelectedSpawnPoint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <!--  Bin Index  -->
                        <StackPanel Grid.Column="2">
                            <TextBlock
                                Margin="0,0,0,5"
                                Style="{StaticResource LabelStyle}"
                                Text="Bin Index" />
                            <ComboBox ItemsSource="{Binding MilestoneConfig.BinIndices}" SelectedItem="{Binding MilestoneConfig.SelectedBinIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!--  Numeric Values Section  -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <TextBlock Style="{StaticResource LabelStyle}" Text="Bounty" />
                            <TextBox Text="{Binding MilestoneConfig.Bounty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>


                        <StackPanel Grid.Column="1" Margin="0,0,15,0">
                            <TextBlock Style="{StaticResource LabelStyle}" Text="Goal Easy" />
                            <TextBox Text="{Binding MilestoneConfig.GoalEasy, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,15,0">
                            <TextBlock Style="{StaticResource LabelStyle}" Text="Goal Hard" />
                            <TextBox Text="{Binding MilestoneConfig.GoalHard, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>