<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>WinExe</OutputType>
        <TargetFramework>net6.0-windows</TargetFramework>
        <ApplicationIcon>Assets\app.ico</ApplicationIcon>
        <RootNamespace>Maximus</RootNamespace>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <UseWPF>true</UseWPF>
        <PackageId>Maximus</PackageId>
        <Version>1.1.0</Version>
        <AssemblyVersion>1.1.0</AssemblyVersion>
        <FileVersion>1.1.0</FileVersion>
        <SelfContained>false</SelfContained>
        <PublishSingleFile>false</PublishSingleFile>
        <OutputPath>$(MSBuildThisFileDirectory)..\bin\SharedBuild\$(Configuration)\</OutputPath>
        <PublishDir>$(MSBuildThisFileDirectory)..\bin\SharedBuild\$(Configuration)\</PublishDir>
        <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Configuration)' == 'Release'">
        <DebugType>none</DebugType>
        <DebugSymbols>false</DebugSymbols>
    </PropertyGroup>

    <ItemGroup>
      <Page Update="Views\MainWindow.xaml">
        <Generator>MSBuild:Compile</Generator>
        <XamlRuntime>Wpf</XamlRuntime>
        <SubType>Designer</SubType>
      </Page>
      <Page Update="Views\Page\RacePage.xaml">
        <Generator>MSBuild:Compile</Generator>
        <XamlRuntime>Wpf</XamlRuntime>
        <SubType>Designer</SubType>
      </Page>
      <Page Update="Views\Page\BlackListPage.xaml">
        <Generator>MSBuild:Compile</Generator>
        <XamlRuntime>Wpf</XamlRuntime>
        <SubType>Designer</SubType>
      </Page>
      <Page Update="Views\Page\AboutAuthorPage.xaml">
        <Generator>MSBuild:Compile</Generator>
        <XamlRuntime>Wpf</XamlRuntime>
        <SubType>Designer</SubType>
      </Page>
    </ItemGroup>

    <ItemGroup>
      <Folder Include="Assets\" />
    </ItemGroup>

    <ItemGroup>
      <None Remove="Assets\Map.png" />
      <Resource Include="Assets\Map.png" />
      <None Remove="Assets\MAIN_ICON_TOP_15.png" />
      <Resource Include="Assets\blacklist.png" />
      <None Remove="Assets\MILESTONE_INFRACTIONS.png" />
      <Resource Include="Assets\milestones.png" />
      <None Remove="Assets\RIVAL_RACE.png" />
      <Resource Include="Assets\races.png" />
      <None Remove="Assets\ENGAGE.png" />
      <Resource Include="Assets\ENGAGE.png" />
      <None Remove="Assets\LEADERBOARD.png" />
      <Resource Include="Assets\LEADERBOARD.png" />
      <None Remove="Assets\LOCK.png" />
      <Resource Include="Assets\LOCK.png" />
      <None Remove="Assets\Map_Icon.png" />
      <Resource Include="Assets\Map_Icon.png" />
      <None Remove="Assets\MILESTONE.png" />
      <Resource Include="Assets\MILESTONE.png" />
      <None Remove="Assets\POLICE_PARAMETRS.png" />
      <Resource Include="Assets\POLICE_PARAMETRS.png" />
      <None Remove="Assets\RACE.png" />
      <Resource Include="Assets\RACE.png" />
      <None Remove="Assets\RACE_OPTIONS_CHALLENGE_SERIES_RACE.png" />
      <Resource Include="Assets\RACE_OPTIONS_CHALLENGE_SERIES_RACE.png" />
      <None Remove="Assets\RACE_OPTIONS_COPS_IN_RACE.png" />
      <Resource Include="Assets\RACE_OPTIONS_COPS_IN_RACE.png" />
      <None Remove="Assets\RACE_OPTIONS_PROLOGUE_RACE.png" />
      <Resource Include="Assets\RACE_OPTIONS_PROLOGUE_RACE.png" />
      <None Remove="Assets\RACE_OPTIONS_QUICK_RACE.png" />
      <Resource Include="Assets\RACE_OPTIONS_QUICK_RACE.png" />
      <None Remove="Assets\STRELKA.png" />
      <Resource Include="Assets\STRELKA.png" />
    </ItemGroup>

    <ItemGroup>
      <Compile Update="Services\Generation\Builders\RaceScriptBuilderCombine.cs">
        <DependentUpon>RaceScriptBuilder.cs</DependentUpon>
      </Compile>
    </ItemGroup>

    <ItemGroup>
      <Compile Include="..\Shared\UpdatePackageSettings.cs" Link="Shared\UpdatePackageSettings.cs" />
    </ItemGroup>

    <ItemGroup>
      <None Remove="Assets\app.ico" />
      <Resource Include="Assets\app.ico" />
      <None Remove="Assets\ANGLES.png" />
      <Resource Include="Assets\ANGLES.png" />
    </ItemGroup>

    <Target Name="CleanPublishOutput" AfterTargets="Publish">
        <ItemGroup>
            <_PublishPdb Include="$(PublishDir)**\*.pdb" />
            <_PublishExtraJson Include="$(PublishDir)**\*.json"
                              Exclude="$(PublishDir)$(AssemblyName).deps.json;$(PublishDir)$(AssemblyName).runtimeconfig.json;$(PublishDir)Updater.deps.json;$(PublishDir)Updater.runtimeconfig.json" />
        </ItemGroup>

        <Delete Files="@(_PublishPdb)" />
        <Delete Files="@(_PublishExtraJson)" />
    </Target>

</Project>
