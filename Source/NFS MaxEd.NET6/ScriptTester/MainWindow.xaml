<Window
    Background="{StaticResource BackgroundDark}"
    Height="500"
    Title="Script Tester"
    Width="900"
    x:Class="ScriptTester.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  HEADER  -->
        <StackPanel>
            <TextBlock Style="{StaticResource H1Style}" Text="Script Runner" />

            <TextBlock Style="{StaticResource CaptionStyle}" Text="Execute scripts and view output" />
        </StackPanel>

        <!--  CONTROL PANEL  -->
        <Border
            Background="{StaticResource BackgroundMedium}"
            BorderBrush="{StaticResource BorderColor}"
            BorderThickness="1"
            CornerRadius="8"
            Grid.Row="2"
            Padding="15">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  SECTION TITLE  -->
                <TextBlock Style="{StaticResource H3Style}" Text="Execution" />

                <!--  OUTPUT  -->
                <Border
                    Background="{StaticResource BackgroundLight}"
                    BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Grid.Row="2"
                    Padding="10">

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock
                            FontFamily="Consolas"
                            Foreground="{StaticResource TextPrimary}"
                            Style="{StaticResource BodyStyle}"
                            Text="Output will appear here..."
                            TextWrapping="Wrap"
                            x:Name="OutputTextBlock" />
                    </ScrollViewer>
                </Border>

                <!--  ACTIONS  -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button
                        Click="RunScriptButton_Click"
                        Content="Сравнить"
                        Grid.Column="0"
                        Style="{StaticResource ButtonStyle}" />
                </Grid>
            </Grid>
        </Border>

        <!--  FOOTER  -->
        <TextBlock
            Grid.Row="3"
            HorizontalAlignment="Right"
            Style="{StaticResource CaptionStyle}"
            Text="Script Tester v1.0" />
    </Grid>
</Window>