<Window
    Height="450"
    Title="MainWindow"
    Width="800"
    mc:Ignorable="d"
    x:Class="ScriptTester.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ScriptTester"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <StackPanel>
            <TextBox
                Height="30"
                Margin="10"
                x:Name="InputTextBox" />
            <Button
                Click="RunScriptButton_Click"
                Content="Run Script"
                Margin="10" />
            <TextBlock
                Margin="10"
                TextWrapping="Wrap"
                x:Name="OutputTextBlock" />
        </StackPanel>
    </Grid>
</Window>
